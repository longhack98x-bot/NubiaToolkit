<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp"
    android:background="@drawable/bg_gaming_gradient">

    <!-- Header Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">
        
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_logo"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:id="@+id/text_app_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_app"
            android:textSize="20sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:fontFamily="sans-serif-black"/>

        <Button
            android:id="@+id/btn_settings"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/btn_settings"
            android:textSize="12sp"
            android:textColor="@color/colorTextPrimary"
            android:background="@drawable/bg_card"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:drawableStart="@drawable/ic_settings"
            android:drawablePadding="8dp"
            android:drawableTint="@color/colorTextPrimary"/>
    </LinearLayout>

    <!-- Main Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_gaming_card"
        android:padding="24dp"
        android:elevation="8dp"
        android:gravity="center_horizontal">

        <!-- Status Warning -->
        <TextView
            android:id="@+id/text_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/status_checking"
            android:textAlignment="center"
            android:textColor="@color/colorStatusError"
            android:textSize="14sp"
            android:padding="16dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone"
            android:background="#26F44336"
            android:textStyle="bold"/>

        <!-- Global Toggle -->
        <Switch
            android:id="@+id/switch_global_enable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_global_enable"
            android:textColor="@color/colorTextPrimary"
            android:textSize="17sp"
            android:textStyle="bold"
            android:checked="true"

            android:thumb="@drawable/switch_gaming_thumb"
            android:track="@drawable/switch_gaming_track"
            android:layout_marginBottom="24dp"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginBottom="24dp"/>

        <!-- Feature Toggle -->
        <TextView
            android:id="@+id/title_feature_nokill"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_features"
            android:textColor="@color/colorAccent"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            android:textAllCaps="true"
            android:textSize="12sp"
            android:letterSpacing="0.1"/>

        <Switch
            android:id="@+id/switch_feature_nokill"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_feature_nokill"
            android:textColor="@color/colorTextPrimary"
            android:textSize="16sp"
            android:checked="true"

            android:thumb="@drawable/switch_gaming_thumb"
            android:track="@drawable/switch_gaming_track"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/desc_feature_nokill"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/desc_feature_nokill"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"
            android:layout_marginBottom="16dp"/>

        <Switch
            android:id="@+id/switch_feature_global_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_feature_global_mode"
            android:textColor="@color/colorTextPrimary"
            android:textSize="16sp"
            android:checked="false"
            android:thumb="@drawable/switch_gaming_thumb"
            android:track="@drawable/switch_gaming_track"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/desc_feature_global_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/desc_feature_global_mode"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"
            android:layout_marginBottom="0dp"/>

    </LinearLayout>

    <!-- Footer -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/msg_changes_instant"
        android:textSize="12sp"
        android:textColor="@color/colorTextSecondary"
        android:layout_marginTop="32dp"
        android:alpha="0.6"/>

</LinearLayout>
